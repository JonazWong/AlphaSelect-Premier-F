# ========================================
# AlphaSelect Premier F - Backend 配置範例
# ========================================
# 複製此文件為 .env 並修改相關配置

# Database (Docker 容器內連接)
# 注意: 使用 postgres 作為主機名（Docker 服務名），端口是容器內的 5432
# 如果在容器外連接，請改為 localhost:5433
DATABASE_URL=postgresql://admin:dev_password_123@postgres:5432/alphaselect

# Redis (Docker 容器內連接)
# 注意: 使用 redis 作為主機名（Docker 服務名），端口是容器內的 6379
# 如果在容器外連接，請改為 localhost:6380
REDIS_URL=redis://redis:6379

# MEXC API（可選 - 留空也能啟動系統）
MEXC_API_KEY=
MEXC_SECRET_KEY=
MEXC_CONTRACT_BASE_URL=https://contract.mexc.com
MEXC_SPOT_BASE_URL=https://api.mexc.com

# AI Settings
AI_MODEL_DIR=/app/ai_models
MAX_TRAINING_EPOCHS=200
DEFAULT_BATCH_SIZE=32

# Security（⚠️ 生產環境務必修改 SECRET_KEY！）
SECRET_KEY=dev-secret-key-please-change-in-production-1234567890
ALGORITHM=HS256

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
