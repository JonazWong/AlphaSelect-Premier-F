# Database
# 本機開發：
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/defaultdb

# DigitalOcean 生產環境：
# DATABASE_URL=postgresql://doadmin:YOUR_PASSWORD@premier-do-user-32973725-0.l.db.ondigitalocean.com:25060/defaultdb?sslmode=require

# Redis
REDIS_URL=redis://redis:6379

# MEXC API
MEXC_API_KEY=your-mexc-api-key
MEXC_SECRET_KEY=your-mexc-secret-key
MEXC_CONTRACT_BASE_URL=https://contract.mexc.com
MEXC_SPOT_BASE_URL=https://api.mexc.com

# AI Settings
AI_MODEL_DIR=/app/ai_models
MAX_TRAINING_EPOCHS=200
DEFAULT_BATCH_SIZE=32

# Security
SECRET_KEY=change-this-to-a-secure-random-key-at-least-32-chars
ALGORITHM=HS256

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://frontend:3000

# App
DEBUG=true

# Extra (used by docker-compose postgres service, ignored by Settings)
DB_PASSWORD=your-db-password
